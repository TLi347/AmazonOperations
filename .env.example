DATABASE_URL="file:./dev.db"

# ── OpenRouter ───────────────────────────────────────────────────────
# 从 https://openrouter.ai/keys 获取
ANTHROPIC_API_KEY="sk-or-your-key-here"
ANTHROPIC_BASE_URL="https://openrouter.ai/api/v1"

# ── Claude Code CLI 路径（Agent SDK 需要）───────────────────────────
# 运行 `which claude` 获取路径
CLAUDE_CODE_PATH="/Users/your-username/.local/bin/claude"

# ── 前端默认模型 ────────────────────────────────────────────────────
# 可选值: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
NEXT_PUBLIC_DEFAULT_MODEL="claude-haiku-4-5-20251001"
